# convenience function to output evaluation metrics
def evaluate_classifier(model, X_split, y_split):
    y_pred = model.predict(X_split)
    # Use positive-class probabilities for ROC AUC
    y_pred_prob = model.predict_proba(X_split)[:, 1]

    out = {
        "accuracy": accuracy_score(y_split, y_pred),
        "precision": precision_score(y_split, y_pred, zero_division=0),
        "recall": recall_score(y_split, y_pred, zero_division=0),
        "f1": f1_score(y_split, y_pred, zero_division=0),
        "roc_auc": roc_auc_score(y_split, y_pred_prob),
    }

    return pd.DataFrame([out])


